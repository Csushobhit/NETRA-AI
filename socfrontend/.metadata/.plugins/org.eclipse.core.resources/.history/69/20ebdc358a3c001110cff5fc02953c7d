<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>NETRA-AI — API Keys</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/admin.css}">
</head>
<body>

<nav class="nav">
    <a class="logo-text" href="/dashboard">NETRA-AI</a>
    <div class="nav-right">
        <div class="nav-icons">
            <span title="Analytics">📊</span>
            <span title="Notifications">🔔</span>
            <span title="Settings">⚙️</span>
        </div>
        <div class="user-menu" id="userMenu">
            <div class="user-badge" onclick="toggleMenu()">
                <span class="user-icon-char">👑</span>
                <span th:text="${username} ?: 'Admin'">Admin</span>
                <span style="font-size:10px;opacity:0.5;margin-left:2px;">▾</span>
            </div>
            <div class="dropdown">
                <div class="dropdown-header">Admin Panel</div>
                <a class="dropdown-item" href="/admin/pending"><span class="di-icon">✅</span> User Approvals</a>
                <a class="dropdown-item" href="/admin-ui/ti"><span class="di-icon">🛡️</span> TI Control Panel</a>
                <a class="dropdown-item" href="/admin-ui/audit"><span class="di-icon">📋</span> Audit Logs</a>
                <a class="dropdown-item" href="/admin-ui/keys"><span class="di-icon">🔑</span> API Key Management</a>
                <div class="dropdown-divider"></div>
                <a class="dropdown-item" href="/dashboard"><span class="di-icon">🏠</span> Dashboard</a>
                <div class="dropdown-divider"></div>
                <form th:action="@{/logout}" method="post" style="margin:0;">
                    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                    <button type="submit" class="dropdown-item danger"><span class="di-icon">🚪</span> Logout</button>
                </form>
            </div>
        </div>
        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>
    </div>
</nav>

<div class="page-body">

    <div class="fade-up">
        <div class="page-title">API Key <span>Management</span></div>
        <div class="page-subtitle">Update external TI integration credentials</div>
    </div>

    <div class="card admin-table-wrap fade-up" style="max-width: 620px;">
        <div class="section-header">
            <div class="section-title">Integration Keys</div>
        </div>

        <form method="post" action="/admin-ui/keys">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <div style="display:flex; flex-direction:column; gap:20px;">

                <div class="form-group">
                    <label class="form-label">🔍 AbuseIPDB</label>
                    <input class="form-input" type="text" name="ABUSEIPDB_API_KEY"
                           placeholder="Enter AbuseIPDB API key..." autocomplete="off" />
                </div>

                <div class="form-group">
                    <label class="form-label">🌐 OTX (AlienVault)</label>
                    <input class="form-input" type="text" name="OTX_API_KEY"
                           placeholder="Enter OTX API key..." autocomplete="off" />
                </div>

                <div class="form-group">
                    <label class="form-label">🦠 VirusTotal</label>
                    <input class="form-input" type="text" name="VIRUSTOTAL_API_KEY"
                           placeholder="Enter VirusTotal API key..." autocomplete="off" />
                </div>

                <div class="form-group">
                    <label class="form-label">🤖 OpenAI</label>
                    <input class="form-input" type="text" name="OPENAI_API_KEY"
                           placeholder="Enter OpenAI API key..." autocomplete="off" />
                </div>

                <div style="display:flex; gap:10px; padding-top:4px;">
                    <button type="submit" class="btn btn-primary">💾 Update Keys</button>
                    <a href="/dashboard" class="btn btn-ghost">← Back</a>
                </div>

            </div>
        </form>
    </div>

</div>

<script>
function toggleMenu() {
    document.getElementById('userMenu').classList.toggle('open');
}
document.addEventListener('click', function(e) {
    const menu = document.getElementById('userMenu');
    if (!menu.contains(e.target)) menu.classList.remove('open');
});

let dark = true;
function toggleTheme() {
    dark = !dark;
    const circle = document.getElementById('toggleCircle');
    if (!dark) {
        document.body.classList.add('light');
        circle.innerHTML = '☀️';
        circle.style.transform = 'translateX(30px)';
    } else {
        document.body.classList.remove('light');
        circle.innerHTML = '🌙';
        circle.style.transform = 'translateX(0)';
    }
}
</script>
</body>
</html>