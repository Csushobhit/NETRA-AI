<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Login</title>
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<div class="navbar">
    <div class="logo">Liquid Brokers</div>

    <div class="nav-links">
        <a href="#">About</a>
        <a href="#">Trading</a>
        <a href="#">Contact</a>
        <a href="#">FAQ</a>
        <a href="#">ENG</a>
    </div>

    <div class="auth-buttons">
        <button class="login-btn">Login</button>
        <button class="signup-btn">Sign up</button>
    </div>
</div>

<div class="hero">

    <h1>Elevate Your<br>Trading Experience</h1>

    <p>Unlock your trading potential in a fully regulated environment, powered by Liquid Brokers</p>

    <button class="cta-btn">Sign Up & Trade</button>

</div>

<!-- LOGIN CARD -->
<div class="login-card">

    <h3>Login</h3>

    <form th:action="@{/login}" method="post">

        <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

        <input type="text" name="username" placeholder="Username" required />

        <input type="password" name="password" placeholder="Password" required />

        <button type="submit">Login</button>

    </form>

</div>

</body>
</html>