<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Auth</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/auth.css}">
</head>
<body>

<div class="container">

    <!-- NAVBAR -->
    <div class="nav">

        <!-- LEFT: LOGO -->
        <div class="logo">
            <img th:src="@{/images/logo.png}" alt="logo">
        </div>

        <!-- CENTER: ROBOTIC EYE -->
        <div class="eye-container">
            <div class="eye">
                <div class="inner-eye">
                    <div class="pupil" id="pupil1"></div>
                    <div class="pupil" id="pupil2"></div>
                </div>
            </div>
        </div>

        <!-- RIGHT: THEME TOGGLE -->
        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>

    </div>

    <!-- HERO SECTION -->
    <div class="hero">

        <div class="left">

            <h1>
                Your Trusted Partner<br>
                for IT Security & Project<br>
                Management
            </h1>

            <p>
                We empower organizations to detect threats, analyze risks,
                and secure systems — all with intelligent automation.
            </p>

            <!-- BUTTONS -->
            <div class="cta-group">
                <button class="glass-btn" onclick="openLogin()">Login</button>
                <button class="glass-btn secondary" onclick="openSignup()">Sign Up</button>
            </div>

        </div>

        <div class="right">
            <!-- DEFAULT DARK IMAGE -->
            <img id="heroImage" th:src="@{/images/hero-dark.png}">
        </div>

    </div>

</div>

<!-- LOGIN MODAL -->
<div class="modal" id="loginModal">
    <div class="card">

        <h3>Login</h3>

        <!-- STATUS MESSAGE -->
        <div th:if="${param.error}" class="status error">
            Invalid credentials or not approved
        </div>

        <div th:if="${param.pending}" class="status pending">
            Approval Pending
        </div>

        <form th:action="@{/login}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />

            <button type="submit">Login</button>
        </form>

        <span class="close" onclick="closeAll()">×</span>

    </div>
</div>

<!-- SIGNUP MODAL -->
<div class="modal" id="signupModal">
    <div class="card">

        <h3>Sign Up</h3>

        <!-- STATUS MESSAGE -->
        <div th:if="${error}" class="status error" th:text="${error}"></div>
        <div th:if="${message}" class="status success" th:text="${message}"></div>

        <form th:action="@{/register}" method="post" th:object="${user}">
            <input type="text" th:field="*{name}" placeholder="Name" required />
            <input type="text" th:field="*{username}" placeholder="Username" required />
            <input type="email" th:field="*{email}" placeholder="Email" required />
            <input type="password" th:field="*{password}" placeholder="Password" required />

            <button type="submit">Register</button>
        </form>

        <span class="close" onclick="closeAll()">×</span>

    </div>
</div>

<script>

/* MODALS */
function openLogin() {
    document.getElementById("loginModal").style.display = "flex";
}
function openSignup() {
    document.getElementById("signupModal").style.display = "flex";
}
function closeAll() {
    document.getElementById("loginModal").style.display = "none";
    document.getElementById("signupModal").style.display = "none";
}

/* THEME TOGGLE */
let dark = true;

function toggleTheme() {
    const body = document.body;
    const circle = document.getElementById("toggleCircle");
    const img = document.getElementById("heroImage");

    dark = !dark;

    if (!dark) {
        body.classList.add("light");
        circle.innerHTML = "☀️";
        circle.style.transform = "translateX(30px)";
        img.src = "/images/hero-light.png";
    } else {
        body.classList.remove("light");
        circle.innerHTML = "🌙";
        circle.style.transform = "translateX(0px)";
        img.src = "/images/hero-dark.png";
    }
}

/* ROBOTIC EYE (CONSTRAINED) */
document.addEventListener("mousemove", (e) => {
    const pupils = document.querySelectorAll(".pupil");

    pupils.forEach(pupil => {
        const rect = pupil.parentElement.getBoundingClientRect();

        const x = e.clientX - (rect.left + rect.width / 2);
        const y = e.clientY - (rect.top + rect.height / 2);

        const angle = Math.atan2(y, x);
        const radius = 6;

        const moveX = Math.cos(angle) * radius;
        const moveY = Math.sin(angle) * radius;

        pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
});

</script>

</body>
</html>