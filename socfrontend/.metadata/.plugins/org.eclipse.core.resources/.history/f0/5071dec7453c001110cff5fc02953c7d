body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: radial-gradient(circle at 20% 40%, #4b1d8f 0%, #1a0938 35%, #000000 65%);
    color: white;
}

/* CONTAINER */
.container {
    padding: 30px 100px;
}

/* NAVBAR */
.nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-weight: 600;
    font-size: 18px;
    letter-spacing: 0.5px;
}

.nav-links {
    background: rgba(255,255,255,0.05);
    padding: 10px 20px;
    border-radius: 30px;
    backdrop-filter: blur(10px);
}

.nav-links a {
    margin: 0 15px;
    color: #ddd;
    font-size: 14px;
    text-decoration: none;
}

/* HERO */
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 100px;
}

/* LEFT */
.left {
    max-width: 52%;
}

.left h1 {
    font-size: 54px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.5px;
}

.left p {
    margin-top: 25px;
    color: #b5b5b5;
    font-size: 15px;
    line-height: 1.7;
    max-width: 500px;
}

/* CTA BUTTON */
.cta {
    margin-top: 35px;
    padding: 14px 26px;
    border-radius: 30px;
    border: none;
    background: linear-gradient(90deg, #ff7bff, #7b61ff);
    color: white;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 8px 25px rgba(123,97,255,0.4);
    transition: all 0.3s ease;
}

.cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(123,97,255,0.6);
}

/* RIGHT IMAGE */
.right img {
    width: 480px;
    max-width: 100%;
    background: transparent;
    mix-blend-mode: lighten;
    filter: drop-shadow(0 0 60px rgba(123,97,255,0.25));
}
/* MODAL */
.modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.06);
    padding: 30px;
    border-radius: 18px;
    width: 320px;
    backdrop-filter: blur(18px);
    position: relative;
    box-shadow: 0 0 40px rgba(0,0,0,0.6);
}

.card h3 {
    margin-bottom: 20px;
    font-weight: 600;
}

/* INPUTS */
.card input {
    width: 100%;
    margin-bottom: 12px;
    padding: 12px;
    border-radius: 10px;
    border: none;
    background: rgba(255,255,255,0.08);
    color: white;
    outline: none;
}

/* BUTTON */
.card button {
    width: 100%;
    padding: 12px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
    font-weight: 500;
    cursor: pointer;
}

/* CLOSE */
.close {
    position: absolute;
    top: 12px;
    right: 15px;
    cursor: pointer;
    font-size: 18px;
}