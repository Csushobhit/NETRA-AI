<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>TI Index</title>
</head>
<body>

<h2>Threat Intelligence Index</h2>

<div>
    <a href="/dashboard">Dashboard</a>
</div>

<form method="get" action="/admin-ui/ti">
    <select name="index">
        <option value="known_malicious_ips">Malicious</option>
        <option value="known_risky_ips">High Risk</option>
        <option value="known_low_risky_ips">Low Risk</option>
        <option value="known_unknown_ips">Unknown</option>
    </select>
    <button type="submit">Load</button>
</form>

<table border="1">
    <tr>
        <th>IP</th>
        <th>Action</th>
    </tr>

    <tr th:each="d : ${data}">
        <td th:text="${d.ip}"></td>
        <td>
            <form method="post" action="/admin-ui/delete">
                <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                <input type="hidden" name="index" th:value="${index}" />
                <input type="hidden" name="ip" th:value="${d.ip}" />
                <button type="submit">Delete</button>
            </form>
        </td>
    </tr>
</table>

<form method="post" action="/admin-ui/maltrail">
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
    <button type="submit">Refresh Maltrail</button>
</form>

</body>
</html>