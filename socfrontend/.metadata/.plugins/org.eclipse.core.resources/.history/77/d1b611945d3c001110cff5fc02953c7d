<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" th:href="@{/css/auth.css}">
    <link rel="stylesheet" th:href="@{/css/dashboard.css}">
</head>

<body>

<!-- NAVBAR -->
<div class="nav">

    <div class="logo-text">NETRA-AI</div>

    <div class="nav-right">

        <div class="icons">
            <span>📊</span>
            <span>🔔</span>
            <span>⚙️</span>
        </div>

        <span class="user-icon" th:text="${isAdmin} ? '👑' : '👤'"></span>

        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>

    </div>

</div>

<!-- WELCOME -->
<div class="welcome">

    <div>
        <h2>Welcome, <span th:text="${username}"></span></h2>
        <p>Real-time security monitoring</p>
    </div>

    <form action="/search-ti" method="get" class="search-bar">
        <input type="text" name="ip" placeholder="Search IP..." required>
        <button type="submit">Run TI</button>
    </form>

</div>

<!-- KPI -->
<div class="kpi">

    <div class="card">
        <h4>Total Alerts</h4>
        <p th:text="${stats.total}"></p>
        <canvas id="kpi1"></canvas>
    </div>

    <div class="card">
        <h4>High Risk</h4>
        <p th:text="${stats.suspicious}"></p>
        <canvas id="kpi2"></canvas>
    </div>

    <div class="card">
        <h4>TI Malicious</h4>
        <p th:text="${stats.ti_malicious}"></p>
        <canvas id="kpi3"></canvas>
    </div>

    <div class="card">
        <h4>Normal</h4>
        <p th:text="${stats.normal}"></p>
        <canvas id="kpi4"></canvas>
    </div>

</div>

<!-- GRAPHS -->
<div class="graphs">

    <div class="card large">
        <canvas id="trendChart"></canvas>
    </div>

    <div class="card">
        <canvas id="donutChart"></canvas>
    </div>

    <div class="card">
        <canvas id="barChart"></canvas>
    </div>

</div>

<!-- FILTER -->
<div class="filters">
    <select id="riskFilter">
        <option value="">All</option>
        <option value="high">High Risk</option>
        <option value="suspicious">Suspicious</option>
    </select>
</div>

<!-- TABLE -->
<div class="table-section">

    <form method="post" action="/bulk-ti">
        <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

        <table>
            <thead>
                <tr>
                    <th></th>
                    <th>IP</th>
                    <th>Time</th>
                    <th>Risk</th>
                    <th>Attack</th>
                    <th>TI</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <tr th:each="a : ${alerts}">

                    <td><input type="checkbox" name="ips" th:value="${a['ip']}"></td>

                    <td>
                        <a th:href="@{'/detail/' + ${a['ip']}}" th:text="${a['ip']}"></a>
                    </td>

                    <td th:text="${a['timestamp']}"></td>

                    <td th:text="${a['risk_score']}"></td>

                    <td th:text="${a['action']}"></td>

                    <td th:text="${a['ti_label'] != null ? a['ti_label'] : 'Not Checked'}"></td>

                    <td>
                        <button type="button"
                                th:attr="onclick=|runSingleTI('${a['ip']}')|">
                            Run TI
                        </button>
                    </td>

                </tr>
            </tbody>

        </table>

        <button type="submit">Run Bulk TI</button>

    </form>

</div>

<!-- HIDDEN FORM -->
<form id="singleTIForm" method="post" action="/run-ti" style="display:none;">
    <input type="hidden" name="ip" id="singleIP">
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
</form>

<!-- CHART JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script th:inline="javascript">

const trend = [[${trend}]];
const dist = [[${distribution}]];
const topIps = [[${topIps}]];

/* LINE */
new Chart(document.getElementById("trendChart"), {
    type: 'line',
    data: {
        labels: trend.map(t => t.time),
        datasets: [{
            data: trend.map(t => t.total),
            borderColor: '#7c3aed',
            tension: 0.4
        }]
    }
});

/* DONUT */
new Chart(document.getElementById("donutChart"), {
    type: 'doughnut',
    data: {
        labels: ['Normal', 'Suspicious', 'Malicious'],
        datasets: [{
            data: [dist.normal, dist.suspicious, dist.malicious],
            backgroundColor: ['#22c55e','#facc15','#ef4444']
        }]
    }
});

/* BAR */
new Chart(document.getElementById("barChart"), {
    type: 'bar',
    data: {
        labels: topIps.map(i => i.ip),
        datasets: [{
            data: topIps.map(i => i.count),
            backgroundColor: '#3b82f6'
        }]
    }
});

function toggleTheme() {
    document.body.classList.toggle("light");
}

function runSingleTI(ip) {
    document.getElementById("singleIP").value = ip;
    document.getElementById("singleTIForm").submit();
}

</script>

</body>
</html>