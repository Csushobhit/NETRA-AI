body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(120deg, #3a1c71, #000000 60%);
    color: white;
}

/* CONTAINER */
.container {
    padding: 20px 80px;
}

/* NAVBAR */
.nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-weight: bold;
    font-size: 18px;
}

.nav-links a {
    margin-left: 20px;
    color: #ccc;
    font-size: 14px;
}

/* HERO */
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 80px;
}

/* LEFT */
.left {
    max-width: 50%;
}

.left h1 {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
}

.left p {
    margin-top: 20px;
    color: #bbb;
    font-size: 15px;
    line-height: 1.6;
}

/* BUTTON */
.cta {
    margin-top: 30px;
    padding: 12px 24px;
    border-radius: 25px;
    border: none;
    background: linear-gradient(90deg, #ff7bff, #7b61ff);
    color: white;
    cursor: pointer;
}

/* RIGHT IMAGE */
.right img {
    width: 420px;
    max-width: 100%;
}

/* MODAL */
.modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(6px);
    justify-content: center;
    align-items: center;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.08);
    padding: 25px;
    border-radius: 15px;
    width: 300px;
    backdrop-filter: blur(15px);
    position: relative;
}

.card input {
    width: 100%;
    margin-bottom: 10px;
    padding: 10px;
    border-radius: 8px;
    border: none;
}

.card button {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

.close {
    position: absolute;
    top: 10px;
    right: 15px;
    cursor: pointer;
}