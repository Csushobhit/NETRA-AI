/* ================= BASE ================= */
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    color: white;
    transition: all 0.4s ease;

    background:
        radial-gradient(circle at 20% 40%, rgba(88, 28, 135, 0.95) 0%, transparent 35%),
        radial-gradient(circle at 28% 60%, rgba(59, 130, 246, 0.25) 0%, transparent 40%),
        radial-gradient(circle at 30% 30%, rgba(249, 115, 22, 0.15) 0%, transparent 45%),
        linear-gradient(90deg, #0b031a 0%, #000000 55%);
}

/* ================= LIGHT MODE ================= */
body.light {
    color: #111;

    background:
        radial-gradient(circle at 20% 40%, rgba(147, 197, 253, 0.8) 0%, transparent 35%),
        radial-gradient(circle at 28% 60%, rgba(251, 191, 36, 0.4) 0%, transparent 40%),
        radial-gradient(circle at 30% 30%, rgba(59, 130, 246, 0.3) 0%, transparent 45%),
        linear-gradient(90deg, #ffffff 0%, #ffffff 50%, #000000 55%);
}

/* ================= CONTAINER ================= */
.container {
    padding: 30px 100px;
}

/* ================= NAVBAR ================= */
.nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* LOGO */
.logo img {
    height: 48px;
    object-fit: contain;
}

/* ================= GLASS ================= */
.glass {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(18px);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.12);
}

body.light .glass {
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(0,0,0,0.08);
}

/* ================= EYE ================= */
.eye-container {
    display: flex;
    justify-content: center;
}

.eye {
    width: 60px;
    height: 60px;
    display: flex;
    justify-content: center;
    align-items: center;
}

.inner-eye {
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    border-radius: 6px;
    display: flex;
    justify-content: space-around;
    align-items: center;
}

.pupil {
    width: 8px;
    height: 8px;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    border-radius: 2px;
}

/* ================= THEME TOGGLE ================= */
.theme-toggle {
    width: 70px;
    height: 36px;
    display: flex;
    align-items: center;
    padding: 4px;
    cursor: pointer;
    border-radius: 20px;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(18px);
}

body.light .theme-toggle {
    background: rgba(0,0,0,0.05);
}

.toggle-circle {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(90deg,#ffcc70,#ff9a00);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

/* ================= HERO ================= */
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 100px;
    gap: 40px;
}

.left {
    max-width: 52%;
}

.left h1 {
    font-size: 54px;
    font-weight: 700;
    line-height: 1.15;
}

.left p {
    margin-top: 25px;
    color: #b5b5b5;
    font-size: 15px;
}

body.light .left p {
    color: #555;
}

/* ================= GLASS BUTTONS ================= */
.cta-group {
    margin-top: 35px;
    display: flex;
    gap: 15px;
}

.glass-btn {
    padding: 14px 28px;
    border-radius: 30px;
    border: none;
    cursor: pointer;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(18px);
    color: white;

    border: 1px solid rgba(255,255,255,0.15);
    transition: all 0.3s ease;
}

.glass-btn:hover {
    background: rgba(255,255,255,0.18);
}

body.light .glass-btn {
    background: rgba(0,0,0,0.05);
    color: black;
}

.glass-btn.secondary {
    opacity: 0.7;
}

/* ================= IMAGE ================= */
.right img {
    width: 620px;
    max-width: none;
    transition: all 0.4s ease;
}

.right {
    margin-right: -80px;
}

/* ================= MODAL ================= */
.modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(12px);
    justify-content: center;
    align-items: center;
}

/* ================= CARD ================= */
.card {
    width: 340px;
    padding: 30px;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(25px);

    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.15);

    box-shadow: 0 0 60px rgba(0,0,0,0.6);
}

body.light .card {
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(0,0,0,0.1);
}

/* INPUTS */
.card input {
    width: 100%;
    margin-bottom: 12px;
    padding: 12px;

    border-radius: 10px;
    border: none;

    background: rgba(255,255,255,0.1);
    color: white;
}

body.light .card input {
    background: rgba(0,0,0,0.05);
    color: black;
}

/* BUTTON */
.card button {
    width: 100%;
    padding: 12px;
    border-radius: 10px;
    border: none;

    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
    cursor: pointer;
}

/* CLOSE */
.close {
    position: absolute;
    top: 12px;
    right: 15px;
    cursor: pointer;
}

/* ================= STATUS ================= */
.status {
    padding: 10px;
    border-radius: 10px;
    margin-bottom: 10px;
    font-size: 13px;
    backdrop-filter: blur(12px);
}

/* RED */
.status.error {
    background: rgba(255, 0, 0, 0.15);
    border: 1px solid rgba(255, 0, 0, 0.4);
    color: #ff6b6b;
}

/* YELLOW */
.status.pending {
    background: rgba(255, 193, 7, 0.15);
    border: 1px solid rgba(255, 193, 7, 0.4);
    color: #ffd966;
}

/* GREEN */
.status.success {
    background: rgba(0, 255, 100, 0.15);
    border: 1px solid rgba(0, 255, 100, 0.4);
    color: #7dffb3;
}