<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Dashboard</title>
</head>
<body>

<h2>Dashboard</h2>

<div>
    <form th:action="@{/logout}" method="post">
        <button type="submit">Logout</button>
    </form>
</div>

<div>
    <h3>Stats</h3>

    <div>
        <a th:href="@{/alerts}">
            Total IPs: <span th:text="${stats.total}"></span>
        </a>
    </div>

    <div>
        <a th:href="@{/alerts(filter='suspicious')}">
            Suspicious: <span th:text="${stats.suspicious}"></span>
        </a>
    </div>

    <div>
        <a th:href="@{/alerts}">
            Normal: <span th:text="${stats.normal}"></span>
        </a>
    </div>

    <div>
        <a th:href="@{/alerts}">
            TI Malicious: <span th:text="${stats.ti_malicious}"></span>
        </a>
    </div>

</div>

<div th:if="${isAdmin}">
    <h3>Admin</h3>
    <a href="/admin/pending">User Approvals</a>
</div>

</body>
</html>