<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>NETRA-AI — User Approvals</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/admin.css}">
</head>
<body>

<nav class="nav">
    <a class="logo-text" href="/dashboard">NETRA-AI</a>
    <div class="nav-right">
        <div class="nav-icons">
            <span title="Analytics">📊</span>
            <span title="Notifications">🔔</span>
            <span title="Settings">⚙️</span>
        </div>
        <div class="user-menu" id="userMenu">
            <div class="user-badge" onclick="toggleMenu()">
                <span class="user-icon-char">👑</span>
                <span th:text="${username} ?: 'Admin'">Admin</span>
                <span style="font-size:10px;opacity:0.5;margin-left:2px;">▾</span>
            </div>
            <div class="dropdown">
                <div class="dropdown-header">Admin Panel</div>
                <a class="dropdown-item" href="/admin/pending"><span class="di-icon">✅</span> User Approvals</a>
                <a class="dropdown-item" href="/admin-ui/ti"><span class="di-icon">🛡️</span> TI Control Panel</a>
                <a class="dropdown-item" href="/admin-ui/audit"><span class="di-icon">📋</span> Audit Logs</a>
                <a class="dropdown-item" href="/admin-ui/keys"><span class="di-icon">🔑</span> API Key Management</a>
                <div class="dropdown-divider"></div>
                <a class="dropdown-item" href="/dashboard"><span class="di-icon">🏠</span> Dashboard</a>
                <div class="dropdown-divider"></div>
                <form th:action="@{/logout}" method="post" style="margin:0;">
                    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                    <button type="submit" class="dropdown-item danger"><span class="di-icon">🚪</span> Logout</button>
                </form>
            </div>
        </div>
        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>
    </div>
</nav>

<div class="page-body">

    <div class="fade-up">
        <div class="page-title">User <span>Approvals</span></div>
        <div class="page-subtitle">Review and manage pending user registrations</div>
    </div>

    <div class="card admin-table-wrap fade-up">
        <div class="section-header">
            <div class="section-title">Pending Users</div>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr th:each="u : ${users}">
                    <td th:text="${u.id}" style="color:#6b7280; font-size:12px; font-family:'Courier New',monospace;"></td>
                    <td th:text="${u.name}" style="font-weight:500;"></td>
                    <td th:text="${u.username}" style="color:#a78bfa; font-family:'Courier New',monospace; font-size:12px;"></td>
                    <td th:text="${u.email}" style="color:#94a3b8; font-size:12.5px;"></td>
                    <td><span class="badge badge-pending">Pending</span></td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <form th:action="@{/admin/approve}" method="post" style="margin:0;">
                                <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                                <input type="hidden" name="id" th:value="${u.id}" />
                                <button type="submit" class="btn btn-approve">✓ Approve</button>
                            </form>
                            <form th:action="@{/admin/reject}" method="post" style="margin:0;">
                                <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                                <input type="hidden" name="id" th:value="${u.id}" />
                                <button type="submit" class="btn btn-reject">✕ Reject</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr th:if="${#lists.isEmpty(users)}">
                    <td colspan="6" style="text-align:center; padding:32px; color:#6b7280;">
                        🎉 No pending users at the moment
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

<script>
function toggleMenu() {
    document.getElementById('userMenu').classList.toggle('open');
}
document.addEventListener('click', function(e) {
    const menu = document.getElementById('userMenu');
    if (!menu.contains(e.target)) menu.classList.remove('open');
});

let dark = true;
function toggleTheme() {
    dark = !dark;
    const circle = document.getElementById('toggleCircle');
    if (!dark) {
        document.body.classList.add('light');
        circle.innerHTML = '☀️';
        circle.style.transform = 'translateX(30px)';
    } else {
        document.body.classList.remove('light');
        circle.innerHTML = '🌙';
        circle.style.transform = 'translateX(0)';
    }
}
</script>
</body>
</html>