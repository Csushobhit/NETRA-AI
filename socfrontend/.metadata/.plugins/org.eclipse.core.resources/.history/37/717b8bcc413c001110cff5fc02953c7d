<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>IP Detail</title>
</head>
<body>

<h2>IP Investigation</h2>

<div>
    <a href="/alerts">Back to Alerts</a>
</div>

<h3 th:text="${ip}"></h3>

<hr>

<h3>Decision Summary</h3>

<p><b>Attack Type:</b> <span th:text="${data[0]['attack_type']}"></span></p>

<p><b>Risk Score:</b> <span th:text="${data[0]['risk_score']}"></span></p>

<p><b>Recommended Action:</b> <span th:text="${data[0]['action']}"></span></p>

<p><b>Explanation:</b></p>
<p th:text="${data[0]['explanation']}"></p>

<hr>

<h3>Threat Intelligence</h3>

<p><b>Label:</b> <span th:text="${data[0]['ti_label'] != null ? data[0]['ti_label'] : 'Not Checked'}"></span></p>

<p><b>Confidence:</b> <span th:text="${data[0]['ti_confidence']}"></span></p>

<p><b>Reasoning:</b> <span th:text="${data[0]['ti_reasoning']}"></span></p>

<form method="post" action="/run-ti">
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
    <input type="hidden" name="ip" th:value="${ip}" />
    <button type="submit">Run TI</button>
</form>

<hr>

<h3>Technical Details</h3>

<p>Request Frequency: <span th:text="${data[0]['request_freq']}"></span></p>
<p>Failed Ratio: <span th:text="${data[0]['failed_ratio']}"></span></p>
<p>Unique Ports: <span th:text="${data[0]['unique_ports']}"></span></p>
<p>Anomaly Score: <span th:text="${data[0]['anomaly_score']}"></span></p>
<p>Off Hour Activity: <span th:text="${data[0]['off_hour']}"></span></p>

<hr>

<h3>User Feedback</h3>

<form method="post" action="/feedback">
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
    <input type="hidden" name="ip" th:value="${ip}" />

    <button type="submit" name="feedback" value="correct">Correct</button>
    <button type="submit" name="feedback" value="incorrect">Incorrect</button>
    <button type="submit" name="feedback" value="unknown">Unknown</button>
</form>

</body>
</html>