<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>NETRA-AI — Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- auth.css provides: body background, .logo-text, .theme-toggle, .toggle-circle, body.light -->
    <link rel="stylesheet" th:href="@{/css/auth.css}">
    <link rel="stylesheet" th:href="@{/css/dashboard.css}">
</head>

<body>

<!-- ================================================================
     NAVBAR
     ================================================================ -->
<nav class="nav">

    <div class="logo-text">NETRA-AI</div>

    <div class="nav-right">

        <!-- Icon cluster -->
        <div class="nav-icons">
            <span title="Analytics">📊</span>
            <span title="Notifications">🔔</span>
            <span title="Settings">⚙️</span>
        </div>

        <!-- User badge -->
        <div class="user-badge">
            <span class="user-icon-char" th:text="${isAdmin} ? '👑' : '👤'">👤</span>
            <span th:text="${username} ?: 'User'">User</span>
        </div>

        <!-- Theme toggle -->
        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>

    </div>
</nav>

<!-- ================================================================
     MAIN DASHBOARD
     ================================================================ -->
<main class="dashboard">

    <!-- ── WELCOME + SEARCH ─────────────────────────────────────── -->
    <section class="welcome">

        <div class="welcome-text">
            <h2>Welcome, <span class="username" th:text="${username} ?: 'User'">User</span></h2>
            <p>Real-time security monitoring</p>
        </div>

        <form action="/search-ti" method="get" class="search-bar">
            <input type="text" name="ip" placeholder="Search IP address..." required />
            <button type="submit">Run TI</button>
        </form>

    </section>

    <!-- ── KPI CARDS ────────────────────────────────────────────── -->
    <section class="kpi-grid">

        <div class="card kpi-card">
            <div class="kpi-label">Total Alerts</div>
            <div class="kpi-value" th:text="${stats.total}">1,284</div>
            <canvas class="kpi-spark" id="kpi1"></canvas>
        </div>

        <div class="card kpi-card">
            <div class="kpi-label">High Risk</div>
            <div class="kpi-value" th:text="${stats.suspicious}">342</div>
            <canvas class="kpi-spark" id="kpi2"></canvas>
        </div>

        <div class="card kpi-card">
            <div class="kpi-label">TI Malicious</div>
            <div class="kpi-value" th:text="${stats.ti_malicious}">89</div>
            <canvas class="kpi-spark" id="kpi3"></canvas>
        </div>

        <div class="card kpi-card">
            <div class="kpi-label">Normal</div>
            <div class="kpi-value" th:text="${stats.normal}">853</div>
            <canvas class="kpi-spark" id="kpi4"></canvas>
        </div>

    </section>

    <!-- ── GRAPHS ────────────────────────────────────────────────── -->
    <section class="graphs-grid">

        <!-- Large trend line -->
        <div class="card graph-card large">
    <div class="graph-title">Alert Trend</div>
    <p style="font-size:11px;color:#6b7280;margin-bottom:10px;">Total alerts detected over time — hover for details</p>
    <div class="chart-wrap trend-wrap">
        <canvas id="trendChart"></canvas>
    </div>
</div>

        <!-- Donut -->
        <div class="card graph-card">
    <div class="graph-title">Risk Distribution</div>
    <p style="font-size:11px;color:#6b7280;margin-bottom:10px;">Breakdown of alert severity across all monitored IPs</p>
    <div class="chart-wrap donut-wrap">
        <canvas id="donutChart"></canvas>
    </div>
</div>

        <!-- Bar -->
        <div class="card graph-card">
    <div class="graph-title">Top IP Activity</div>
    <p style="font-size:11px;color:#6b7280;margin-bottom:10px;">IPs generating the highest number of alerts</p>
    <div class="chart-wrap bar-wrap">
        <canvas id="barChart"></canvas>
    </div>
</div>

    <!-- ── FILTER BAR ─────────────────────────────────────────────── -->
    <section class="filter-bar">
        <label for="riskFilter">Filter</label>
        <select id="riskFilter" onchange="filterTable()">
            <option value="">All Alerts</option>
            <option value="high">High Risk</option>
            <option value="suspicious">Suspicious</option>
        </select>
    </section>

    <!-- ── ALERT TABLE ────────────────────────────────────────────── -->
    <section class="card table-wrapper">

        <form method="post" action="/bulk-ti" id="mainForm">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <div class="table-header">
                <h3>Live Alerts</h3>
                <button type="submit" class="bulk-btn">⚡ Run Bulk TI</button>
            </div>

            <table class="alert-table">
                <thead>
                    <tr>
                        <th style="width:36px"></th>
                        <th>IP Address</th>
                        <th>Timestamp</th>
                        <th>Risk Score</th>
                        <th>Attack Type</th>
                        <th>TI Label</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="alertBody">
                    <!--/* Thymeleaf loop */-->
                    <tr th:each="a : ${alerts}"
                        th:attr="data-risk=${a['risk_score']}">

                        <td>
                            <input type="checkbox" name="ips" th:value="${a['ip']}" />
                        </td>

                        <td>
                            <a th:href="@{'/detail/' + ${a['ip']}}"
                               th:text="${a['ip']}">192.168.0.1</a>
                        </td>

                        <td th:text="${a['timestamp']}">2024-01-01 12:00</td>

                        <td>
                            <span th:with="score=${a['risk_score']}"
                                  th:classappend="${score >= 80} ? 'risk-badge risk-high'
                                               : (${score >= 50} ? 'risk-badge risk-medium'
                                               : 'risk-badge risk-low')"
                                  th:text="${score}">75</span>
                        </td>

                        <td th:text="${a['action']}">Port Scan</td>

                        <td>
                            <span th:if="${a['ti_label'] == 'malicious'}" class="ti-malicious">⚠ Malicious</span>
                            <span th:if="${a['ti_label'] == 'clean'}"     class="ti-clean">✔ Clean</span>
                            <span th:if="${a['ti_label'] == null}"        class="ti-none">Not Checked</span>
                        </td>

                        <td>
                            <button type="button" class="ti-btn"
                                    th:attr="onclick=|runSingleTI('${a['ip']}')|">
                                Run TI
                            </button>
                        </td>

                    </tr>
                </tbody>
            </table>

        </form>
    </section>

</main>

<!-- Hidden single-TI form (outside main form to avoid nesting) -->
<form id="singleTIForm" method="post" action="/run-ti" style="display:none;">
    <input type="hidden" name="ip" id="singleIP" />
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
</form>

<!-- ================================================================
     CHART.JS
     ================================================================ -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script th:inline="javascript">
/*<![CDATA[*/

/* ---- DATA FROM THYMELEAF ---- */
const trend        = /*[[${trend}]]*/ [];
const distribution = /*[[${distribution}]]*/ { normal: 60, suspicious: 25, malicious: 15 };
const topIps       = /*[[${topIps}]]*/ [];

/* ---- SHARED DEFAULTS ---- */
Chart.defaults.color = '#94a3b8';
Chart.defaults.font.family = 'Poppins';

function isLight() { return document.body.classList.contains('light'); }

/* ── TREND LINE ─────────────────────────────────────────────── */
const trendChart = new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
        labels: trend.map(t => t.time),
        datasets: [{
            label: 'Alerts',
            data: trend.map(t => t.total),
            borderColor: '#7c3aed',
            backgroundColor: 'rgba(124,58,237,0.12)',
            fill: true,
            tension: 0.45,
            pointRadius: 3,
            pointBackgroundColor: '#7c3aed',
            borderWidth: 2
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: 'rgba(7,2,15,0.85)', titleColor: '#e2e8f0', bodyColor: '#94a3b8' }
        },
        scales: {
            x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { font: { size: 11 } } },
            y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { font: { size: 11 } } }
        }
    }
});

/* ── DONUT ─────────────────────────────────────────────────── */
const donutChart = new Chart(document.getElementById('donutChart'), {
    type: 'doughnut',
    data: {
        labels: ['Normal', 'Suspicious', 'Malicious'],
        datasets: [{
            data: [distribution.normal, distribution.suspicious, distribution.malicious],
            backgroundColor: ['rgba(34,197,94,0.8)', 'rgba(251,191,36,0.8)', 'rgba(239,68,68,0.8)'],
            borderColor: ['#22c55e', '#fbbf24', '#ef4444'],
            borderWidth: 1.5,
            hoverOffset: 6
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
            legend: {
                position: 'bottom',
                labels: { boxWidth: 10, padding: 14, font: { size: 11 } }
            }
        }
    }
});

/* ── BAR ──────────────────────────────────────────────────── */
const barChart = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
        labels: topIps.map(i => i.ip),
        datasets: [{
            label: 'Hits',
            data: topIps.map(i => i.count),
            backgroundColor: 'rgba(6,182,212,0.5)',
            borderColor: '#06b6d4',
            borderWidth: 1.5,
            borderRadius: 6
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { display: false }, ticks: { font: { size: 10 } } },
            y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { font: { size: 10 } } }
        }
    }
});

/* ── KPI SPARKLINES ────────────────────────────────────────── */
function sparkline(id, data, color, label) {
    new Chart(document.getElementById(id), {
        type: 'line',
        data: {
            labels: data.map((_, i) => i),
            datasets: [{
                label: label,
                data,
                borderColor: color,
                borderWidth: 1.8,
                tension: 0.45,
                pointRadius: 0,
                fill: true,
                backgroundColor: color.replace('rgb', 'rgba').replace(')', ', 0.10)')
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: true,
                    position: 'bottom',
                    labels: {
                        boxWidth: 8,
                        boxHeight: 8,
                        padding: 6,
                        font: { size: 10, family: 'Poppins' },
                        color: '#94a3b8'
                    }
                },
                tooltip: { enabled: false }
            },
            scales: { x: { display: false }, y: { display: false } }
        }
    });
}
const trendTotals = trend.map(t => t.total);
const trendHigh   = trend.map(t => t.high);
sparkline('kpi1', trendTotals, 'rgb(167,139,250)', 'Alerts over time');
sparkline('kpi2', trendHigh,   'rgb(248,113,113)', 'High risk trend');
sparkline('kpi3', trendHigh,   'rgb(251,191,36)',  'Malicious detections');
sparkline('kpi4', trendTotals.map(v => Math.max(0, v - (trendHigh[0] || 0))), 'rgb(74,222,128)', 'Normal traffic');

/* ── THEME TOGGLE ─────────────────────────────────────────── */
let dark = true;

function toggleTheme() {
    dark = !dark;
    const body = document.body;
    const circle = document.getElementById('toggleCircle');

    if (!dark) {
        body.classList.add('light');
        circle.innerHTML = '☀️';
        circle.style.transform = 'translateX(30px)';
    } else {
        body.classList.remove('light');
        circle.innerHTML = '🌙';
        circle.style.transform = 'translateX(0)';
    }

    /* Update chart text colours for readability */
    const axisColor = dark ? '#94a3b8' : '#64748b';
    [trendChart, barChart].forEach(c => {
        c.options.scales.x.ticks.color = axisColor;
        c.options.scales.y.ticks.color = axisColor;
        c.update();
    });
    donutChart.options.plugins.legend.labels.color = axisColor;
    donutChart.update();
}

/* ── SINGLE TI ──────────────────────────────────────────── */
function runSingleTI(ip) {
    document.getElementById('singleIP').value = ip;
    document.getElementById('singleTIForm').submit();
}

/* ── TABLE FILTER ──────────────────────────────────────── */
function filterTable() {
    const val = document.getElementById('riskFilter').value.toLowerCase();
    const rows = document.querySelectorAll('#alertBody tr');
    rows.forEach(row => {
        if (!val) { row.style.display = ''; return; }
        const score = parseInt(row.dataset.risk || '0', 10);
        const show = val === 'high' ? score >= 80 : score >= 50 && score < 80;
        row.style.display = show ? '' : 'none';
    });
}

/*]]>*/
</script>

</body>
</html>