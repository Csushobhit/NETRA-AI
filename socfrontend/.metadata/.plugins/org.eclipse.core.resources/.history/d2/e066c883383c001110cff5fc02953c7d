body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: black;
    color: white;
    overflow: hidden;
}

/* NAV */
.nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 60px;
    align-items: center;
}

.links a {
    margin: 0 12px;
    color: #aaa;
    font-size: 14px;
}

.actions button {
    margin-left: 10px;
    padding: 8px 16px;
    border-radius: 20px;
    border: none;
    background: transparent;
    color: white;
}

.actions .primary {
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

/* HERO */
.hero {
    text-align: center;
    margin-top: 120px;
}

.tag {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    background: rgba(255,255,255,0.1);
    font-size: 12px;
    margin-bottom: 20px;
}

.hero h1 {
    font-size: 56px;
    font-weight: 600;
}

.hero p {
    color: #aaa;
    margin-top: 10px;
}

.cta {
    margin-top: 20px;
    padding: 12px 30px;
    border-radius: 25px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

/* BLOB */
.blob {
    position: absolute;
    bottom: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 400px;
    background: radial-gradient(circle, #ff7bff, #7b61ff, transparent);
    filter: blur(120px);
}

/* MODAL */
.modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.08);
    padding: 25px;
    border-radius: 15px;
    width: 300px;
    backdrop-filter: blur(15px);
    position: relative;
}

.card input {
    width: 100%;
    margin-bottom: 10px;
    padding: 10px;
    border-radius: 8px;
    border: none;
}

.card button {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

.close {
    position: absolute;
    top: 10px;
    right: 15px;
    cursor: pointer;
}