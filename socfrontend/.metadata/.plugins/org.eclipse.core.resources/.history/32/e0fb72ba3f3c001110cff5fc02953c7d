body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: black;
    color: white;
    overflow: hidden;
}

/* NAV */
.nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 60px;
    align-items: center;
}

.links a {
    margin: 0 12px;
    color: #aaa;
    font-size: 14px;
}

.actions button {
    margin-left: 10px;
    padding: 8px 16px;
    border-radius: 20px;
    border: none;
    background: transparent;
    color: white;
}

.actions .primary {
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

/* HERO */
.hero {
    text-align: center;
    margin-top: 120px;
}

.tag {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    background: rgba(255,255,255,0.1);
    font-size: 12px;
    margin-bottom: 20px;
}

.hero h1 {
    font-size: 60px;
    font-weight: 700;
    color: white;
}

.hero p {
    color: #aaa;
    margin-top: 10px;
}

.cta {
    margin-top: 20px;
    padding: 12px 30px;
    border-radius: 25px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
    box-shadow: 0 0 20px rgba(123,97,255,0.5);
}

/* REALISTIC GLOW SPHERE */
.blob {
    position: absolute;
    bottom: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 550px;

    background:
        radial-gradient(circle at 50% 40%, #ff5ec4 0%, transparent 40%),
        radial-gradient(circle at 60% 60%, #ff7a18 0%, transparent 50%),
        radial-gradient(circle at 40% 60%, #7b61ff 0%, transparent 55%),
        radial-gradient(circle at 50% 100%, #ff00cc 0%, #2a004f 70%, black 100%);

    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.95;
}

.blob::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, white 0%, transparent 60%);
    opacity: 0.08;
}

/* STARS BACKGROUND */
body::after {
    content: "";
    position: fixed;
    width: 100%;
    height: 100%;
    background:
        radial-gradient(2px 2px at 20% 30%, white, transparent),
        radial-gradient(1px 1px at 70% 60%, white, transparent),
        radial-gradient(1.5px 1.5px at 50% 80%, white, transparent),
        radial-gradient(1px 1px at 90% 20%, white, transparent),
        radial-gradient(1px 1px at 10% 70%, white, transparent),
        radial-gradient(1px 1px at 40% 10%, white, transparent),
        radial-gradient(1px 1px at 80% 40%, white, transparent);
    opacity: 0.5;
    z-index: -1;
}

/* MODAL */
.modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.08);
    padding: 25px;
    border-radius: 15px;
    width: 300px;
    backdrop-filter: blur(15px);
    position: relative;
    box-shadow: 0 0 30px rgba(123,97,255,0.2);
}

.card input {
    width: 100%;
    margin-bottom: 10px;
    padding: 10px;
    border-radius: 8px;
    border: none;
}

.card button {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: none;
    background: linear-gradient(90deg,#ff7bff,#7b61ff);
    color: white;
}

.close {
    position: absolute;
    top: 10px;
    right: 15px;
    cursor: pointer;
}