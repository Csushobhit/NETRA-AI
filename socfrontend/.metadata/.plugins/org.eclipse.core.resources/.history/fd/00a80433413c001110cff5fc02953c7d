<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Auth</title>
    <link rel="stylesheet" th:href="@{/css/auth.css}">
</head>
<body>

<div class="container">

    <!-- NAVBAR -->
    <div class="nav">
        <div class="logo">SecureSOC</div>

        <div class="nav-links">
            <a>Home</a>
            <a>About Us</a>
            <a>Contact Us</a>
            <a>Services</a>
        </div>
    </div>

    <!-- HERO SECTION -->
    <div class="hero">

        <div class="left">

            <h1>
                Your Trusted Partner<br>
                for IT Security & Project<br>
                Management
            </h1>

            <p>
                We empower organizations to detect threats, analyze risks,
                and secure systems — all with intelligent automation.
            </p>

            <button class="cta" onclick="openLogin()">Login →</button>

        </div>

        <div class="right">
            <img src="/images/hero.png" alt="hero">
        </div>

    </div>

</div>

<!-- LOGIN MODAL -->
<div class="modal" id="loginModal">
    <div class="card">

        <h3>Login</h3>

        <form th:action="@{/login}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />

            <button type="submit">Login</button>
        </form>

        <span class="close" onclick="closeAll()">×</span>

    </div>
</div>

<script>
function openLogin() {
    document.getElementById("loginModal").style.display = "flex";
}
function closeAll() {
    document.getElementById("loginModal").style.display = "none";
}
</script>

</body>
</html>