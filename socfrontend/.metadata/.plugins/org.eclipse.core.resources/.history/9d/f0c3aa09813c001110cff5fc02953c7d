<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>NETRA-AI — TI Control Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/admin.css}">
</head>
<body>

<nav class="nav">
    <a class="logo-text" href="/dashboard">NETRA-AI</a>
    <div class="nav-right">
        <div class="nav-icons">
            <span title="Analytics">📊</span>
            <span title="Notifications">🔔</span>
            <span title="Settings">⚙️</span>
        </div>
        <div class="user-menu" id="userMenu">
            <div class="user-badge" onclick="toggleMenu()">
                <span class="user-icon-char">👑</span>
                <span th:text="${username} ?: 'Admin'">Admin</span>
                <span style="font-size:10px;opacity:0.5;margin-left:2px;">▾</span>
            </div>
            <div class="dropdown">
                <div class="dropdown-header">Admin Panel</div>
                <a class="dropdown-item" href="/admin/pending"><span class="di-icon">✅</span> User Approvals</a>
                <a class="dropdown-item" href="/admin-ui/ti"><span class="di-icon">🛡️</span> TI Control Panel</a>
                <a class="dropdown-item" href="/admin-ui/audit"><span class="di-icon">📋</span> Audit Logs</a>
                <a class="dropdown-item" href="/admin-ui/keys"><span class="di-icon">🔑</span> API Key Management</a>
                <div class="dropdown-divider"></div>
                <a class="dropdown-item" href="/dashboard"><span class="di-icon">🏠</span> Dashboard</a>
                <div class="dropdown-divider"></div>
                <form th:action="@{/logout}" method="post" style="margin:0;">
                    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                    <button type="submit" class="dropdown-item danger"><span class="di-icon">🚪</span> Logout</button>
                </form>
            </div>
        </div>
        <div class="theme-toggle" onclick="toggleTheme()">
            <div class="toggle-circle" id="toggleCircle">🌙</div>
        </div>
    </div>
</nav>

<div class="page-body">

    <div class="fade-up">
        <div class="page-title">TI <span>Control Panel</span></div>
        <div class="page-subtitle">Manage threat intelligence indexes and maltrail data</div>
    </div>

    <!-- Index selector + refresh -->
    <div style="display:flex; align-items:center; gap:12px;" class="fade-up">
        <form method="get" action="/admin-ui/ti" style="display:flex; align-items:center; gap:10px;">
            <select class="form-select" name="index">
                <option value="known_malicious_ips"   th:selected="${index == 'known_malicious_ips'}">🔴 Malicious IPs</option>
                <option value="known_risky_ips"       th:selected="${index == 'known_risky_ips'}">🟡 High Risk IPs</option>
                <option value="known_low_risky_ips"   th:selected="${index == 'known_low_risky_ips'}">🟢 Low Risk IPs</option>
                <option value="known_unknown_ips"     th:selected="${index == 'known_unknown_ips'}">⚪ Unknown IPs</option>
            </select>
            <button type="submit" class="btn btn-primary">Load Index</button>
        </form>

        <form method="post" action="/admin-ui/maltrail" style="margin:0;">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
            <button type="submit" class="btn btn-ghost">🔄 Refresh Maltrail</button>
        </form>
    </div>

    <!-- TI Table -->
    <div class="card admin-table-wrap fade-up">
        <div class="section-header">
            <div class="section-title" th:text="${index}">Index</div>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>IP Address</th>
                    <th style="width:120px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <tr th:each="d : ${data}">
                    <td>
                        <span style="font-family:'Courier New',monospace; font-size:13px; color:#67e8f9;"
                              th:text="${d.ip}"></span>
                    </td>
                    <td>
                        <form method="post" action="/admin-ui/delete" style="margin:0;">
                            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />
                            <input type="hidden" name="index" th:value="${index}" />
                            <input type="hidden" name="ip" th:value="${d.ip}" />
                            <button type="submit" class="btn btn-danger">🗑 Delete</button>
                        </form>
                    </td>
                </tr>
                <tr th:if="${data == null or #lists.isEmpty(data)}">
                    <td colspan="2" style="text-align:center; padding:32px; color:#6b7280;">
                        📭 No entries in this index
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

<script>
function toggleMenu() {
    document.getElementById('userMenu').classList.toggle('open');
}
document.addEventListener('click', function(e) {
    const menu = document.getElementById('userMenu');
    if (!menu.contains(e.target)) menu.classList.remove('open');
});

let dark = true;
function toggleTheme() {
    dark = !dark;
    const circle = document.getElementById('toggleCircle');
    if (!dark) {
        document.body.classList.add('light');
        circle.innerHTML = '☀️';
        circle.style.transform = 'translateX(30px)';
    } else {
        document.body.classList.remove('light');
        circle.innerHTML = '🌙';
        circle.style.transform = 'translateX(0)';
    }
}
</script>
</body>
</html>