<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Bulk TI</title>
</head>
<body>

<h2>Bulk TI Results</h2>

<table border="1">
    <tr>
        <th>IP</th>
        <th>Label</th>
        <th>Confidence</th>
    </tr>

    <tr th:each="r : ${results}">
        <td th:text="${r.ip}"></td>
        <td th:text="${r.label}"></td>
        <td th:text="${r.confidence}"></td>
    </tr>

</table>

<a href="/alerts">Back</a>

</body>
</html>