<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Auth</title>
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<div class="nav">
    <div class="logo">Nexo</div>

    <div class="links">
        <a>Home</a>
        <a>Features</a>
        <a>AI Insights</a>
        <a>How It Works</a>
        <a>Get Started</a>
    </div>

    <div class="actions">
        <button onclick="openLogin()">Login</button>
        <button class="primary" onclick="openSignup()">Sign up</button>
    </div>
</div>

<div class="hero">

    <div class="tag">AI Market Insights</div>

    <h1>AI that sees the<br>market before you do</h1>

    <p>Turn predictions into profits with real-time insights.</p>

    <button class="cta" onclick="openLogin()">Login</button>

</div>

<div class="blob"></div>

<!-- LOGIN MODAL -->
<div class="modal" id="loginModal">
    <div class="card">
        <h3>Login</h3>

        <form th:action="@{/login}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />

            <button type="submit">Login</button>
        </form>

        <span class="close" onclick="closeAll()">×</span>
    </div>
</div>

<!-- SIGNUP MODAL -->
<div class="modal" id="signupModal">
    <div class="card">
        <h3>Sign Up</h3>

        <form th:action="@{/register}" method="post" th:object="${user}">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

            <input type="text" th:field="*{name}" placeholder="Name" required />
            <input type="text" th:field="*{username}" placeholder="Username" required />
            <input type="email" th:field="*{email}" placeholder="Email" required />
            <input type="password" th:field="*{password}" placeholder="Password" required />

            <button type="submit">Sign up</button>
        </form>

        <span class="close" onclick="closeAll()">×</span>
    </div>
</div>

<script>
function openLogin() {
    document.getElementById("loginModal").style.display = "flex";
}
function openSignup() {
    document.getElementById("signupModal").style.display = "flex";
}
function closeAll() {
    document.getElementById("loginModal").style.display = "none";
    document.getElementById("signupModal").style.display = "none";
}
</script>

</body>
</html>