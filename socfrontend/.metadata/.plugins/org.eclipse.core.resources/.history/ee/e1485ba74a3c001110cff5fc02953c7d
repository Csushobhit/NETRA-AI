<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Update API Keys</title>
</head>
<body>

<h2>Update API Keys</h2>

<a href="/dashboard">Dashboard</a>

<form method="post" action="/admin-ui/keys">

    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}" />

    <div>
        <label>AbuseIPDB:</label>
        <input type="text" name="ABUSEIPDB_API_KEY" />
    </div>

    <div>
        <label>OTX:</label>
        <input type="text" name="OTX_API_KEY" />
    </div>

    <div>
        <label>VirusTotal:</label>
        <input type="text" name="VIRUSTOTAL_API_KEY" />
    </div>

    <div>
        <label>OpenAI:</label>
        <input type="text" name="OPENAI_API_KEY" />
    </div>

    <button type="submit">Update</button>

</form>

</body>
</html>