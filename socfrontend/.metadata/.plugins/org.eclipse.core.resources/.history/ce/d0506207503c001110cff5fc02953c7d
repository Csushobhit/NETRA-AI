/* ================= BASE ================= */
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    color: white;
    transition: all 0.4s ease;

    background:
        radial-gradient(circle at 20% 40%, rgba(88, 28, 135, 0.95) 0%, transparent 35%),
        radial-gradient(circle at 28% 60%, rgba(59, 130, 246, 0.25) 0%, transparent 40%),
        radial-gradient(circle at 30% 30%, rgba(249, 115, 22, 0.15) 0%, transparent 45%),
        linear-gradient(90deg, #0b031a 0%, #000000 55%);
}

/* ================= LIGHT MODE ================= */
body.light {
    color: #111;

    background:
        radial-gradient(circle at 20% 40%, rgba(147, 197, 253, 0.8) 0%, transparent 35%),
        radial-gradient(circle at 28% 60%, rgba(251, 191, 36, 0.4) 0%, transparent 40%),
        radial-gradient(circle at 30% 30%, rgba(59, 130, 246, 0.3) 0%, transparent 45%),
        #ffffff;
}

/* ================= CONTAINER ================= */
.container {
    padding: 30px 100px;
}

/* ================= NAV ================= */
.nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* LOGO */
.logo-text {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 1px;

    background: linear-gradient(90deg, #8b5cf6, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

body.light .logo-text {
    background: linear-gradient(90deg, #2563eb, #0ea5e9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* ================= THEME TOGGLE ================= */
.theme-toggle {
    width: 70px;
    height: 36px;
    display: flex;
    align-items: center;
    padding: 4px;
    border-radius: 20px;
    cursor: pointer;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
}

body.light .theme-toggle {
    background: rgba(0,0,0,0.05);
}

.toggle-circle {
    width: 28px;
    height: 28px;
    border-radius: 50%;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 14px;
    transition: all 0.3s ease;

    background: #0b1a3a;
}

body.light .toggle-circle {
    background: #38bdf8;
}

/* ================= HERO ================= */
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 100px;
}

.left {
    max-width: 50%;
}

.left h1 {
    font-size: 54px;
    font-weight: 700;
}

.left p {
    margin-top: 20px;
    color: #b5b5b5;
}

body.light .left p {
    color: #555;
}

/* ================= BUTTONS ================= */
.cta-group {
    margin-top: 30px;
    display: flex;
    gap: 15px;
}

.glass-btn {
    padding: 14px 26px;
    border-radius: 30px;
    border: none;
    cursor: pointer;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(18px);
    color: white;

    border: 1px solid rgba(255,255,255,0.15);

    transition: all 0.25s ease;
}

/* HOVER LIFT */
.glass-btn:hover {
    transform: translateY(-3px);
    background: rgba(255,255,255,0.18);
}

body.light .glass-btn {
    background: rgba(0,0,0,0.05);
    color: black;
    border: 1px solid rgba(0,0,0,0.1);
}

/* ================= IMAGE ================= */
.right img {
    width: 620px;
}

.right {
    margin-right: -80px;
}

/* ================= MODAL ================= */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;

    width: 100%;
    height: 100%;

    justify-content: center;
    align-items: center;

    background: rgba(0,0,0,0.25);
    backdrop-filter: blur(20px);

    z-index: 999;
}

body.light .modal {
    background: rgba(255,255,255,0.2);
}

/* ================= CARD ================= */
.card {
    width: 360px;
    padding: 35px 30px;

    border-radius: 20px;

    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(30px);

    border: 1px solid rgba(255,255,255,0.15);

    box-shadow:
        0 10px 40px rgba(0,0,0,0.6),
        inset 0 1px 1px rgba(255,255,255,0.1);

    transform: scale(0.9);
    opacity: 0;
    animation: modalIn 0.25s ease forwards;
}

/* LIGHT MODE GLASS */
body.light .card {
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(35px);

    border: 1px solid rgba(255,255,255,0.6);

    box-shadow:
        0 10px 30px rgba(0,0,0,0.1),
        inset 0 1px 1px rgba(255,255,255,0.8);
}

/* ================= MODAL ANIMATION ================= */
@keyframes modalIn {
    to {
        transform: scale(1);
        opacity: 1;
    }
}

/* ================= FORM ================= */
.card form {
    display: flex;
    flex-direction: column;
}

/* INPUT */
.card input {
    width: 100%;
    margin-bottom: 14px;
    padding: 14px;

    border-radius: 12px;
    border: none;

    font-size: 14px;

    background: rgba(255,255,255,0.08);
    color: white;

    box-shadow: inset 0 2px 4px rgba(0,0,0,0.4);
}

/* INPUT FOCUS GLOW */
.card input:focus {
    outline: none;
    box-shadow:
        0 0 0 2px rgba(123,97,255,0.6),
        inset 0 2px 4px rgba(0,0,0,0.4);
}

body.light .card input {
    background: rgba(255,255,255,0.7);
    color: #111;

    box-shadow: inset 0 2px 4px rgba(0,0,0,0.08);
}

body.light .card input:focus {
    box-shadow:
        0 0 0 2px rgba(37, 99, 235, 0.4),
        inset 0 2px 4px rgba(0,0,0,0.08);
}

/* BUTTON */
.card button {
    width: 100%;
    padding: 14px;
    margin-top: 10px;

    border-radius: 14px;
    border: none;

    font-weight: 500;
    cursor: pointer;

    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(20px);
    color: white;

    border: 1px solid rgba(255,255,255,0.2);

    transition: all 0.25s ease;
}

/* BUTTON HOVER */
.card button:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.2);
}

body.light .card button {
    background: rgba(255,255,255,0.6);
    color: #111;
    border: 1px solid rgba(0,0,0,0.1);
}

/* CLOSE */
.close {
    position: absolute;
    top: 12px;
    right: 15px;
    cursor: pointer;
}

/* ================= STATUS ================= */
.status {
    padding: 12px;
    border-radius: 12px;
    margin-bottom: 12px;
    font-size: 13px;
    backdrop-filter: blur(15px);
}

/* ERROR */
.status.error {
    background: rgba(255, 0, 0, 0.08);
    border: 1px solid rgba(255, 0, 0, 0.25);
    color: #ff4d4d;
}

/* PENDING */
.status.pending {
    background: rgba(255, 193, 7, 0.12);
    border: 1px solid rgba(255, 193, 7, 0.3);
    color: #ffcc33;
}

/* SUCCESS */
.status.success {
    background: rgba(0, 255, 100, 0.12);
    border: 1px solid rgba(0, 255, 100, 0.4);
    color: #7dffb3;
}